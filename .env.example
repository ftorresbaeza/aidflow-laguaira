# Base de datos (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/aidflow?sslmode=require"

# Auth.js - genera con: openssl rand -base64 32
AUTH_SECRET=""

# QR JWT signing - genera con: openssl rand -base64 32 (debe ser DIFERENTE al AUTH_SECRET)
QR_SECRET_KEY=""

# URL de la app
NEXTAUTH_URL="https://aidflow-laguaira.vercel.app"

# Admin inicial (se usa en prisma/seed.ts)
ADMIN_EMAIL="admin@aidflow.ve"
ADMIN_PASSWORD="cambia-esta-contrasena-inmediatamente!"
